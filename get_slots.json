{
  "type": "object",
  "properties": {
    "timeZone": {
      "type": "string",
      "pattern": "[A-Za-z]+(?:/[A-Za-z_]+)+$",
      "description": "Strict IANA time zone identifier(e.g.,'America/New_York','Europe/London')"
    },
    "requestedDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "The requested appointment date in YYYY-MM-DD format."
    }
  },
  "required": [
    "requestedDate",
    "timeZone"
  ]
}
