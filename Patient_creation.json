{
  "type": "object",
  "properties": {
    "appointment_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "The appointment date in YYYY-MM-DD format."
    },
    "timeZone": {
      "type": "string",
      "pattern": "[A-Za-z]+(?:/[A-Za-z_]+)+$",
      "description": "Strict IANA time zone identifier(e.g.,'America/New_York','Europe/London')"
    },
    "appointment_time": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
      "description": "The appointment time in 24-hour HH:MM format."
    },
    "first_name": {
      "type": "string",
      "description": "The first name of the person booking the appointment."
    }
  },
  "required": [
    "appointment_date",
    "appointment_time",
    "timeZone",
    "first_name"
  ]
}
